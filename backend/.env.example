APP_NAME=PredictOdds Pro API
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/predictodds
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=replace-with-a-32-character-or-longer-secret
FERNET_KEY=REPLACE_WITH_BASE64_FERNET_KEY
ACCESS_TOKEN_MINUTES=720
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_DEMO_BASE_URL=https://demo-api.kalshi.co/trade-api/v2
ALPACA_TRADING_URL=https://paper-api.alpaca.markets
ALPACA_MARKET_DATA_URL=https://data.alpaca.markets
ALPACA_AUTH_URL=https://authx.alpaca.markets/v1/oauth2/token
PRIMARY_PROVIDER=kalshi
USE_EXTERNAL_MARKETS=true
DEFAULT_B_PARAM=1800
DEFAULT_MAKER_REBATE_BPS=10
MOCK_MODE=true
RATE_LIMIT_PER_MINUTE=90
